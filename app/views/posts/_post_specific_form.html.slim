.bg-dark.text-white.p-3.rounded

  h2 = post.title
  h5 Posted on #{post.created_at.strftime("%B %d, %Y")}

  - if post.feature
    h6 FEATURED

  h6
    | Posted by 
    - if post.user.present?
      = link_to post.user.name, user_path(post.user.name), data: { turbo: false }
    - elsif post.customer.present?
      = link_to post.customer.name, customer_path(post.customer.name), data: { turbo: false }

  h6 = pluralize(post.likes_count, "like")
  h6 = pluralize(post.views, "view")
  
  = post.body&.html_safe

