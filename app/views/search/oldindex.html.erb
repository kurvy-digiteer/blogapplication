<h1 class="text-center"><%= pluralize(@posts.count, "Result") %></h1>

<div class="container">
    <table class="table table-dark table-striped">
        <thead>
            <tr>
                <tr></tr>
                <th>Title</th>
                <th>Blog content</th>
                <th>Users/Customers</th>
            </tr>
        </thead>

        <tbody>
            <% @posts.each do |post| %>
            <tr>
                <td><%= link_to post.title, post %></td> 
                <td><%= post.body.to_plain_text.truncate_words(25) %></td>
                <% if post.user.present? %>
                    <td><%= link_to post.user.name, post.user %></td>
                <% else %>
                    <td><%= link_to post.customer.name, post.customer %></td>
                <% end %>
            </tr>
            <% end %>
        </tbody>
    </table>
</div>