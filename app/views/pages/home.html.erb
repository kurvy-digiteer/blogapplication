<div class="container">
  <h1>Personal Home Page</h1>

  <% if current_user %>
    <% if current_user.user? %>
        <p>Hello <%= current_user.name %> </p>
        <p>You are a [<%= current_user.role_name %>] </p>
    <% end %>

    <% if current_user.admin? %>
      <p>Hello <%= current_user.name %> </p>
      <p>You are an [<%= current_user.role_name %>] </p>
      There are <%= pluralize(User.count, "user") %> in the website.
    <% end %>
  <% else %>
    <p>Welcome, guest! Please <%= link_to "sign in", user_login_path %> or <%= link_to "sign up", user_signup_path %>.</p>
  <% end %>

  <p>Read more about me! Or check the rest of the site</p>
  <%= link_to "About me", about_path, class:"btn btn-primary" %>
  <%= link_to "Blog/Posts", posts_path, class:"btn btn-primary"%>
</div>