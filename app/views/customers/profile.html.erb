<div class="container mt-4">
  <div class="row">
    <div class="col-md-8 offset-md-2">
      <div class="card">
        <div class="card-body">
          <h2 class="card-title"><%= @customer.name %></h2>
          <p class="card-text"><strong>Email:</strong> <%= @customer.email %></p>
          <p class="card-text"><strong>Member since:</strong> <%= @customer.created_at.strftime("%B %d, %Y") %></p>
          <p class="card-text"><strong>Profile views:</strong> <%= @customer.views %></p>
        </div>
      </div>

      <div class="mt-4">
        <h3>Posts by <%= @customer.name %></h3>
        <% @customer.posts.each do |post| %>
          <div class="card mb-3">
            <div class="card-body">
              <h5 class="card-title"><%= link_to post.title, post_path(post) %></h5>
              <p class="card-text"><small class="text-muted">Posted on <%= post.created_at.strftime("%B %d, %Y") %></small></p>
              <p class="card-text"><small class="text-muted"><%= pluralize(post.views, "view") %></small></p>
            </div>
          </div>
        <% end %>
      </div>

      <div class="mt-4">
        <h3>Comments by <%= @customer.name %></h3>
        <% @customer.comments.each do |comment| %>
          <div class="card mb-3">
            <div class="card-body">
              <p class="card-text"><%= comment.body %></p>
              <p class="card-text">
                <small class="text-muted">
                  On post: <%= link_to comment.post.title, post_path(comment.post) %>
                </small>
              </p>
              <p class="card-text">
                <small class="text-muted">
                  Posted on <%= comment.created_at.strftime("%B %d, %Y") %>
                </small>
              </p>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div> 