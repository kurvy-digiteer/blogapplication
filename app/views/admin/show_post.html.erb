<div class="container">
  <h1 class = "text-center">Admin Dashboard</h1>
  <%= render "admin/nav_links"%>

  <div class ="text-center mt-5"> 
    <div class = "btn-group">
      <%= link_to "Edit", edit_post_path(@post), class: "btn btn-warning" %>
      <%= link_to "Delete", admin_destroy_post_path(@post), data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete this post?" }, class: "btn btn-danger" %>
    </div>
  

    <div class= "row mt-1">
        <p>
            <strong>Title:</strong> <%= @post.title %>
        </p>
    </div>
    
    <div class= "row mt-1">
        <p>
            <strong>Views:</strong> <%= @post.views %>
        </p>
    </div>
    
    <div class= "row mt-1">
        <p>
            <strong>Author:</strong> 
            <%= "#{@post.user.name} | (#{@post.user.email})" %>
        </p>
    </div>

    <div class= "row mt-1">
        <p>
            <strong>Body:</strong> <%= @post.body %>
        </p>
    </div>

    <div class= "row mt-1">
        <p>
            <strong>Comments: </strong> <%= pluralize(@post.comments.count, "Comment") %>
        </p>
        <div class="row mt-1">
            <% @post.comments.each do |comment| %>
                <div class="row mt-1">
                    <strong><%= comment.user.name %>:</strong>
                    <p class="mb-1"><%= comment.body %></p>
                </div>
            <% end %>
        </div>
    </div>  


</div>

</div>
