<div class="container">
  <h1 class="text-center">Admin Dashboard</h1>
  <%= render "admin/nav_links" %>

  <table class="table table-dark table-striped">
    <thead>
      <tr>
        <th scope="col">ID</th>
        <th scope="col">Post</th>
        <th scope="col">Author</th>
        <th scope="col">Comments</th>
        <th scope="col">Actions</th>
      </tr>
    </thead>

    <tbody>
      <% @posts.each do |post| %>
        <tr>
          <th scope="row"><%= post.id %></th>
          <td><%= post.title.truncate(15) %></td>
          <td><%= post.user.name %></td>
          <td><%= pluralize(post.comments.count, "Comment") %></td>
          <td>
            <%= link_to "View", admin_post_path(post), class: "btn btn-primary btn-sm" %>
            <%= button_to "Delete", admin_post_path(post), method: :delete, class: "btn btn-danger btn-sm", form: { data: { turbo_confirm: "Are you sure you want to delete this post?" } } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div> 